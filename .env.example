SECRET_KEY=<64-char hex — generate with: python -c "import secrets; print(secrets.token_hex(32))">
FLASK_ENV=production
SESSION_TYPE=filesystem
SESSION_FILE_DIR=flask_session
SESSION_PERMANENT=false
RATELIMIT_OTP_SEND=5 per hour

TWILIO_ACCOUNT_SID=         # From console.twilio.com → Account Info
TWILIO_AUTH_TOKEN=          # From console.twilio.com → Account Info
TWILIO_VERIFY_SERVICE_SID=  # Twilio console → Verify → Services → create one → SID (starts with VA)

HAPI_BASE_URL=https://hapi.bis.local
HAPI_TOKEN=                 # Bearer token for HAPI student database API

LDAP_SERVER=
LDAP_PORT=636
LDAP_CA_CERT_PATH=
LDAP_SERVICE_ACCOUNT_DN=
LDAP_SERVICE_ACCOUNT_PASS=
LDAP_SEARCH_BASE=
LDAP_USER_SEARCH_FILTER=(sAMAccountName={username})

ADMIN_USERNAME=admin
ADMIN_PASSWORD_HASH=

SQLALCHEMY_DATABASE_URI=sqlite:///data/audit.db
HOST=0.0.0.0
PORT=8080
